---
import Base from "../../layouts/Base.astro";
import { sanityClient } from "../../lib/sanity";
import { allPostsQuery, singlePostQuery } from "../../lib/queries";
import { PortableText } from "astro-portabletext";

interface PostListing {
  _id: string;
  slug: { current: string };
}

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt: string;
  excerpt?: string;
  body: unknown[];
  featuredImageUrl?: string;
  featuredImageAlt?: string;
}

// Static mode: prerender every published post at build time.
// Sanity webhook to Vercel deploy hook triggers a fresh build on publish.
export async function getStaticPaths() {
  const posts = await sanityClient.fetch<PostListing[]>(allPostsQuery);
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch<Post | null>(singlePostQuery, { slug });

if (!post) {
  return Astro.redirect("/404");
}

const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<Base title={post.title} description={post.excerpt}>
  <article class="post-article">
    <a href="/" class="post-back-link">
      <span aria-hidden="true">&larr;</span> Blog
    </a>

    <header class="post-header">
      <h1 class="post-title">{post.title}</h1>
      {formattedDate && (
        <time datetime={post.publishedAt} class="post-date">
          {formattedDate}
        </time>
      )}
    </header>

    {post.featuredImageUrl && (
      <img
        src={`${post.featuredImageUrl}?w=1200&auto=format`}
        alt={post.featuredImageAlt ?? post.title}
        class="post-cover"
        loading="lazy"
        decoding="async"
      />
    )}

    <div class="post-body">
      <PortableText value={post.body} />
    </div>
  </article>

  <aside class="subscribe-cta">
    <h2 class="subscribe-cta__heading">Stay in the loop</h2>
    <p class="subscribe-cta__text">
      New posts on Octant research, epoch recaps, and ecosystem news. Subscribe on Substack.
    </p>
    <a
      href="https://octant.substack.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="subscribe-cta__btn"
    >
      Subscribe on Substack
    </a>
  </aside>
</Base>

<style>
  .post-back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-8);
    transition: color 150ms ease;
  }

  .post-back-link:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .post-header {
    margin-bottom: var(--space-10);
  }

  .post-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-2);
  }

  .post-date {
    display: block;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-top: var(--space-2);
  }

  .post-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 6px;
    display: block;
    margin-bottom: var(--space-10);
  }

  /* PortableText body typography */
  .post-body {
    font-size: var(--text-md);
    line-height: 1.75;
    color: var(--text-primary);
  }

  .post-body :global(p) {
    margin-top: 1.5rem;
  }

  .post-body :global(p:first-child) {
    margin-top: 0;
  }

  .post-body :global(h2) {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-body :global(a) {
    color: var(--color-teal);
    text-decoration: none;
  }

  .post-body :global(a:hover) {
    text-decoration: underline;
  }

  .post-body :global(code) {
    font-family: var(--font-code);
    font-size: 0.9375rem;
    background-color: var(--surface-overlay);
    padding: 2px 6px;
    border-radius: 2px;
    color: var(--text-primary);
  }

  .post-body :global(pre) {
    font-family: var(--font-code);
    font-size: var(--text-sm);
    background-color: var(--surface-overlay);
    color: var(--text-primary);
    padding: 16px 20px;
    border-radius: 4px;
    overflow-x: auto;
    margin-top: 1.5rem;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-teal);
    padding-left: var(--space-6);
    margin-top: 1.5rem;
    color: var(--text-secondary);
    font-style: italic;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-top: 1.5rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin-top: 0.5rem;
  }
</style>
