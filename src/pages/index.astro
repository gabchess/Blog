---
import Base from "../layouts/Base.astro";
import { sanityClient } from "../lib/sanity";
import { allPostsQuery } from "../lib/queries";

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt: string;
  excerpt?: string;
  featuredImageUrl?: string;
  featuredImageAlt?: string;
}

const posts = await sanityClient.fetch<Post[]>(allPostsQuery);
---

<Base title="Octant Blog">
  <div class="hero">
    <h1 class="hero__title">Octant Blog</h1>
    <p class="hero__descriptor">Infrastructure thinking for yield-to-growth.</p>
  </div>

  {
    posts.length === 0 ? (
      <p class="post-list-empty">No posts published yet.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-card">
            {post.featuredImageUrl && (
              <img
                src={`${post.featuredImageUrl}?w=1200&auto=format`}
                alt={post.featuredImageAlt ?? post.title}
                class="post-card__cover"
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="post-card__body">
              <a
                href={`/blog/${post.slug.current}`}
                class="post-card__title"
              >
                {post.title}
              </a>
              {post.publishedAt && (
                <time
                  datetime={post.publishedAt}
                  class="post-card__date"
                >
                  {new Date(post.publishedAt).toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              )}
              {post.excerpt && (
                <p class="post-card__excerpt">{post.excerpt}</p>
              )}
            </div>
          </li>
        ))}
      </ul>
    )
  }
</Base>

<style>
  .post-list-empty {
    color: var(--text-secondary);
  }
</style>
